# Environment Variables
# Copy this file to .env.local and fill in the actual values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development

# Contact & Communication
CONTACT_EMAIL=info@shivratech.com
ADMIN_EMAIL=admin@shivratech.com

# Email Service Configuration (Choose one provider)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@shivratech.com

# Alternative: SendGrid
SENDGRID_API_KEY=

# Alternative: Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Database Configuration
DB_PROVIDER=postgresql
DATABASE_URL=postgresql://user:password@localhost:5432/shivra_tech
DB_HOST=localhost
DB_PORT=5432
DB_USER=shivra_user
DB_PASSWORD=secure_password
DB_NAME=shivra_tech

# Google Maps (for contact page map)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Third Party Services
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key
API_KEY=your-api-key-for-external-services

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CHAT=false

